<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup / device-to-device transfer rules.
  Encrypted credential prefs are device-bound (Keystore) and excluded from transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
        <exclude domain="sharedpref" path="grid_secure_credentials" />
        <exclude domain="sharedpref" path="grid_secure_credentials.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
        <exclude domain="sharedpref" path="grid_secure_credentials" />
        <exclude domain="sharedpref" path="grid_secure_credentials.xml" />
    </device-transfer>
</data-extraction-rules>
